{
  "name": "n8n-nodes-spark",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Spark Protocol (SparkLend) providing 22 resources and 200+ operations for DeFi lending, borrowing, collateral management, flash loans, and sDAI integration on Ethereum and Gnosis.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-spark.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-spark#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-spark/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "spark",
    "sparklend",
    "defi",
    "lending",
    "borrowing",
    "makerdao",
    "ethereum",
    "gnosis",
    "aave",
    "flash-loans",
    "sdai",
    "blockchain",
    "web3",
    "crypto"
  ],
  "main": "dist/nodes/Spark/Spark.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SparkNetwork.credentials.js",
      "dist/credentials/SparkApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Spark/Spark.node.js",
      "dist/nodes/Spark/SparkTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist/",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ethers": "^6.9.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "axios": "^1.6.2",
    "bignumber.js": "^9.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}